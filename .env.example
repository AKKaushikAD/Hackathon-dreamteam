# ─────────────────────────────────────────────────────────────────────────────
# Agent Testing & Evaluation Framework — environment configuration
# Copy this file to `.env` and adjust as needed.
# ─────────────────────────────────────────────────────────────────────────────

# The LLM engine is the Claude Code CLI (`claude`). No API key is required as
# long as you are logged in (`claude` uses your existing OAuth session).
# Path to the claude binary (leave as "claude" if it is on your PATH):
CLAUDE_BINARY=claude

# Models (must be valid `claude --model` identifiers).
# Primary is used for orchestration & final synthesis; judge/fast for the many
# per-rule evaluation calls (cheaper/faster models keep runs affordable).
# These must be valid for YOUR claude login. If a run fails with
# "Invalid model name", pick ids your key accepts (e.g. claude-haiku-4-5,
# claude-sonnet-4-5, claude-sonnet-4-6, claude-opus-4-8).
ATF_PRIMARY_MODEL=claude-opus-4-8
ATF_JUDGE_MODEL=claude-sonnet-4-6
ATF_FAST_MODEL=claude-haiku-4-5

# Per-call timeout (seconds) for a single `claude -p` invocation.
ATF_LLM_TIMEOUT=120

# Retry policy for transient CLI/LLM failures.
ATF_MAX_RETRIES=3

# Concurrency: how many test cases to run in parallel.
ATF_MAX_CONCURRENT_TESTS=4

# Per-test-case wall-clock timeout (seconds).
ATF_TEST_TIMEOUT=90

# ── OPTIONAL: only if you switch LLMBackend to the Anthropic HTTP API ──
# ANTHROPIC_API_KEY=sk-ant-...
